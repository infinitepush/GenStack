{
  "name": "@genstack/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build && node dist/server.js",
    "build": "npm run build --workspace @genstack/config-types && tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "npm run typecheck --workspace @genstack/config-types && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@genstack/config-types": "0.1.0",
    "@prisma/client": "^5.22.0",
    "archiver": "^8.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "jsonrepair": "^3.14.0",
    "multer": "^2.1.1",
    "papaparse": "^5.5.3",
    "pino": "^9.5.0",
    "pino-http": "^10.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/papaparse": "^5.5.2"
  }
}
